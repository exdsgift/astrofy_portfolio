---
import BaseLayout from "../layouts/BaseLayout.astro";
import FeaturedProjects from "../components/FeaturedProjects.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5 relative min-h-[480px]">
    <div class="relative z-10">
      <div class="text-xl py-1">Hey there 👋</div>
      <div class="text-5xl font-bold">I'm <span class="text-primary">Gabriele</span></div>
      <div class="text-3xl py-3 font-bold min-h-[4rem]">
        <span id="typewriter-text"></span><span id="cursor">|</span>
      </div>
      <div class="py-2">
        <text class="text-lg">
          ML/AI Engineer and EU Vulcanus Fellow in Japan (one of 23 selected across Europe from 500+ applicants). I work at the intersection of research and production: real-time speech-to-animation systems, agentic LLM pipelines, and open-source privacy-focused NLP tooling. Previously shipped RAG infrastructure and agentic workflows to production as a Data Scientist. I care about systems that hold up outside the lab. Feel free to explore my projects and blog to see what I'm up to! 🚀
        </text>
      </div>
      <div class="mt-8">
        <a class="btn btn-primary" href="https://www.linkedin.com/in/gabrieledurante/" target="_blank"> Let's connect!</a>
        <a href="https://github.com/exdsgift" target="_blank" class="btn btn-outline ml-5">
          GitHub
        </a>
      </div>
    </div>
  </div>

  <!-- Terminal Easter Egg FAB -->
  <div class="fixed bottom-6 right-6 z-50">
    <button id="terminal-fab" class="btn btn-circle btn-primary shadow-lg hover:scale-110 transition-transform" aria-label="Open Terminal">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
    </button>
  </div>

  <!-- Terminal Modal -->
  <div id="terminal-modal" class="fixed inset-0 z-[60] hidden flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
    <div class="bg-[#1a1b26] w-full max-w-2xl rounded-lg shadow-2xl border border-gray-700 overflow-hidden font-mono text-sm text-gray-300">
      <div class="bg-[#24283b] px-4 py-2 flex items-center justify-between border-b border-gray-700">
        <div class="flex space-x-2">
          <div class="w-3 h-3 rounded-full bg-[#f7768e]"></div>
          <div class="w-3 h-3 rounded-full bg-[#e0af68]"></div>
          <div class="w-3 h-3 rounded-full bg-[#9ece6a]"></div>
        </div>
        <div class="text-xs text-gray-500 uppercase tracking-widest">gabriele_agent.sh</div>
        <button id="close-terminal" class="text-gray-500 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <div id="terminal-body" class="p-6 h-96 overflow-y-auto space-y-2">
        <div class="flex"><span class="text-[#bb9af7] mr-2">$</span> <span id="terminal-input"></span><span class="animate-pulse">_</span></div>
        <div id="terminal-output" class="space-y-1"></div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      // --- Typewriter Effect ---
      let typewriterId = null;
      function initTypewriter() {
        const textElement = document.getElementById("typewriter-text");
        if (!textElement) return;
        const phrases = ["Data Scientist", "ML/AI Engineer", "NLP Specialist", "Vulcanus Fellow"];
        let phraseIndex = 0;
        let charIndex = 0;
        let isDeleting = false;
        if (typewriterId) clearTimeout(typewriterId);
        function type() {
          const currentPhrase = phrases[phraseIndex];
          if (isDeleting) charIndex--; else charIndex++;
          textElement.textContent = currentPhrase.substring(0, charIndex);
          let speed = isDeleting ? 50 : 100;
          if (!isDeleting && charIndex === currentPhrase.length) {
            isDeleting = true;
            speed = 2000;
          } else if (isDeleting && charIndex === 0) {
            isDeleting = false;
            phraseIndex = (phraseIndex + 1) % phrases.length;
            speed = 500;
          }
          typewriterId = setTimeout(type, speed);
        }
        type();
      }

      // --- Terminal Easter Egg ---
      function initTerminal() {
        const fab = document.getElementById('terminal-fab');
        const modal = document.getElementById('terminal-modal');
        const closeBtn = document.getElementById('close-terminal');
        const body = document.getElementById('terminal-body');
        const input = document.getElementById('terminal-input');
        const output = document.getElementById('terminal-output');
        
        if (!fab || !modal || fab.hasAttribute('data-initialized')) return;
        fab.setAttribute('data-initialized', 'true');

        const asciiArt = `\\,,/(^_^)\\,,/`;

        const commands = [
          { text: "./run_portfolio_scan.sh", delay: 500 },
          { text: "> Initializing Agentic Workflow...", type: 'system', delay: 1000 },
          { text: "> Scanning repositories: exdsgift/SynapseLink, exdsgift/NerGuard...", type: 'system', delay: 800 },
          { text: "> Found 142 commits. Key impact: +91.8% efficiency in speech-to-anim.", type: 'success', delay: 1200 },
          { text: "> Analyzing skills core...", type: 'system', delay: 500 },
          { text: "Detected: [PyTorch, LLMs, RAG, NLP, Tokyo_Vibes]", type: 'info', delay: 1000 },
          { text: "> Status: Vulcanus Fellow 2025/2026 ACTIVE", type: 'success', delay: 800 },
          { text: "> Gabriele is ready for production.", type: 'info', delay: 1500 }
        ];

        async function typeCommand(text, element) {
          for (let i = 0; i <= text.length; i++) {
            element.textContent = text.substring(0, i);
            await new Promise(r => setTimeout(r, 40));
          }
        }

        async function runSequence() {
          output.innerHTML = '';
          input.textContent = '';
          
          // Print ASCII Art immediately
          const artDiv = document.createElement('pre');
          artDiv.className = 'text-[#7aa2f7] font-bold leading-tight mb-4';
          artDiv.textContent = asciiArt;
          output.appendChild(artDiv);

          await new Promise(r => setTimeout(r, 400));
          await typeCommand(commands[0].text, input);
          
          for (let i = 1; i < commands.length; i++) {
            await new Promise(r => setTimeout(r, commands[i].delay));
            const div = document.createElement('div');
            if (commands[i].type === 'success') div.className = 'text-[#9ece6a]';
            if (commands[i].type === 'info') div.className = 'text-[#7aa2f7]';
            if (commands[i].type === 'system') div.className = 'text-gray-500 italic';
            div.textContent = commands[i].text;
            output.appendChild(div);
            body.scrollTop = body.scrollHeight;
          }
        }

        fab.addEventListener('click', () => {
          modal.classList.remove('hidden');
          runSequence();
        });

        closeBtn.addEventListener('click', () => modal.classList.add('hidden'));
        modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.add('hidden'); });
      }

      document.addEventListener("astro:page-load", () => {
        initTypewriter();
        initTerminal();
      });
    })();
  </script>

  <style>
    #cursor {
      animation: blink 1s infinite;
      margin-left: 2px;
    }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }
  </style>
  <div>
    <div class="text-3xl w-full font-bold mb-2">My latest projects</div>
  </div>
  <FeaturedProjects />

  {
    last_posts.length > 0 && (
      <>
        <div>
          <div class="text-3xl w-full font-bold mb-5 mt-10">Latest from blog</div>
        </div>
        {last_posts.map((post) => (
          <>
            <HorizontalCard
              title={post.data.title}
              img={post.data.heroImage}
              desc={post.data.description}
              url={"/blog/" + createSlug(post.data.title, post.slug)}
              target="_self"
              badge={post.data.badge}
            />
            <div class="divider my-0" />
          </>
        ))}
      </>
    )
  }
</BaseLayout>
