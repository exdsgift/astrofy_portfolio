---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5 relative min-h-[480px]">
    <div class="relative z-10">
      <div class="text-xl py-1">Hey there 👋</div>
      <div class="text-5xl font-bold">I'm <span class="text-primary">Gabriele</span></div>
      <div class="text-3xl py-3 font-bold min-h-[4rem]">
        <span id="typewriter-text"></span><span id="cursor">|</span>
      </div>
      <div class="py-2">
        <text class="text-lg">
          ML/AI Engineer and EU Vulcanus Fellow in Japan (one of 23 selected across Europe from 500+ applicants). I work at the intersection of research and production: real-time speech-to-animation systems, agentic LLM pipelines, and open-source privacy-focused NLP tooling. Previously shipped RAG infrastructure and agentic workflows to production as a Data Scientist. I care about systems that hold up outside the lab. Feel free to explore my projects and blog to see what I'm up to! 🚀
        </text>
      </div>
      <div class="mt-8">
        <a class="btn btn-primary" href="https://www.linkedin.com/in/gabrieledurante/" target="_blank"> Let's connect!</a>
        <a href="https://github.com/exdsgift" target="_blank" class="btn btn-outline ml-5">
          GitHub
        </a>
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      let typewriterId = null;

      function initTypewriter() {
        const textElement = document.getElementById("typewriter-text");
        if (!textElement) return;

        const phrases = ["Data Scientist", "ML/AI Engineer", "NLP Specialist", "Vulcanus Fellow"];
        let phraseIndex = 0;
        let charIndex = 0;
        let isDeleting = false;

        if (typewriterId) clearTimeout(typewriterId);

        function type() {
          const currentPhrase = phrases[phraseIndex];
          if (isDeleting) charIndex--; else charIndex++;

          textElement.textContent = currentPhrase.substring(0, charIndex);

          let speed = isDeleting ? 50 : 100;
          if (!isDeleting && charIndex === currentPhrase.length) {
            isDeleting = true;
            speed = 2000;
          } else if (isDeleting && charIndex === 0) {
            isDeleting = false;
            phraseIndex = (phraseIndex + 1) % phrases.length;
            speed = 500;
          }
          typewriterId = setTimeout(type, speed);
        }
        type();
      }

      document.addEventListener("astro:page-load", initTypewriter);
      if (document.readyState === "complete") initTypewriter();
      else window.addEventListener("load", initTypewriter);
    })();
  </script>

  <style>
    #cursor {
      animation: blink 1s infinite;
      margin-left: 2px;
    }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }
  </style>
  <div>
    <div class="text-3xl w-full font-bold mb-2">My last projects</div>
  </div>
<HorizontalCard
  title="NerGuard"
  img="/images/screen1.png"
  desc="A privacy-focused tool designed to detect PII quickly, enabling secure RAG and privacy-first AI applications."
  url="https://github.com/exdsgift/NerGuard"
  badge="NLP"
/>
<HorizontalCard
  title="SynapseLink"
  img="/images/Screenshot 2026-03-05 at 16.22.03.png"
  desc="real-time audio-driven facial animation system generating 52 blendshapes at 25 fps (204× faster than real-time, single GPU). Designed a custom training objective for expressiveness (+91.8% over baseline), achieving a 7–43× lighter model than FaceFormer/CodeTalker."
  url="https://github.com/exdsgift/intella-synapse-link"
  badge="AI"
/>

  <!-- <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Latest from blog</div>
  </div> -->

