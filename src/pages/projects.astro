---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title = "Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">AI & Data Science Projects</div>
  </div>

  <HorizontalCard
    title="NerGuard"
    img="/astrofy_portfolio/post_img.webp"
    desc="A privacy-focused tool designed to detect PII (Personally Identifiable Information) quickly, enabling secure RAG (Retrieval-Augmented Generation) and privacy-first AI applications."
    url="https://github.com/exdsgift"
    badge="NLP"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="nv-ingest (Fork)"
    img="/astrofy_portfolio/post_img.webp"
    desc="A specialized fork of NVIDIA’s NeMo-Retriever for parsing complex, unstructured enterprise documents (PDFs, etc.) into metadata and text for embeddings."
    url="https://github.com/exdsgift"
  />

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Entrepreneurship & Innovation</div>
  </div>

  <HorizontalCard
    title="Linkr (AnklePiar)"
    img="/astrofy_portfolio/post_img.webp"
    desc="Winner of the University Startup Challenge 2024. A platform that connects university students with companies to provide financial support in exchange for future work commitments."
    url="https://github.com/exdsgift"
    badge="AWARD WINNER"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Entrepreneurship Club Polimi"
    img="/astrofy_portfolio/post_img.webp"
    desc="Leadership and community building for the largest student association at Politecnico di Milano."
    url="https://github.com/exdsgift"
  />
</BaseLayout>
