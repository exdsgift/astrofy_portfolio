---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Profile</div>
  </div>

  <div class="mb-10 text-justify">
    Data Scientist specializing in Natural Language Processing (NLP) and Large Language Models (LLMs). 
    Currently based in Tokyo, focusing on building privacy-first AI solutions and advanced dialog systems. 
    "Human-first" approach to technology with a strong background in entrepreneurship and social innovation. 
    EU Bioeconomy Youth Ambassador and former Vice President of the Entrepreneurship Club Polimi.
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="Specialized coursework in NLP"
      subtitle="2024 at University of Oslo, Oslo, Norway"
    />
    <TimeLineElement
      title="Management Engineering (Ingegneria Gestionale)"
      subtitle="at Politecnico di Milano, Milan, Italy"
    />
    <TimeLineElement
      title="Machine Learning and Neural Networks Research"
      subtitle="at University of Verona, Verona, Italy"
    />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Data Scientist"
      subtitle="Current at Equmenopolis, Tokyo, Japan"
    >
      Developing AI-driven conversational agents and NLP solutions with a focus on privacy and advanced interaction.
    </TimeLineElement>
    <TimeLineElement
      title="Data Scientist"
      subtitle="at High Performance Analytics"
    >
      Involved in high-level data analysis and machine learning implementations for complex datasets.
    </TimeLineElement>
    <TimeLineElement
      title="Vice President"
      subtitle="at Entrepreneurship Club Polimi, Milan, Italy"
    >
      Led the largest student association at Politecnico di Milano, fostering a community of future entrepreneurs through workshops and networking events.
    </TimeLineElement>
    <TimeLineElement
      title="EU Bioeconomy Youth Ambassador"
      subtitle="at European Commission"
    >
      Representing youth perspectives in the transition towards a sustainable, circular bioeconomy in Europe.
    </TimeLineElement>
    <TimeLineElement
      title="Co-founder / Team Lead"
      subtitle="at Linkr (AnklePiar)"
    >
      Winner of the University Startup Challenge 2024. Developed a platform connecting university students with companies to provide financial support in exchange for future work commitments.
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Certifications</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>
      <a href="https://www.linkedin.com/in/gabrieledurante/" target="_blank"> Check LinkedIn for full list of certifications</a>
    </li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <ul class="list-disc md:columns-5 columns-2 mx-6">
    <li>NLP</li>
    <li>LLMs</li>
    <li>Python</li>
    <li>PyTorch</li>
    <li>TensorFlow</li>
    <li>Deep Learning</li>
    <li>Dialog Systems</li>
    <li>Instruction Tuning</li>
    <li>SQL</li>
    <li>Entrepreneurship</li>
    <li>Leadership</li>
    <li>Public Speaking</li>
    <li>Social Impact</li>
    <li>Italian (Native)</li>
    <li>English (Fluent)</li>
    <li>Japanese (Basic)</li>
  </ul>
</BaseLayout>
