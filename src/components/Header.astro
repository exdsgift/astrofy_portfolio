---
import ThemeSelector from "./ThemeSelector.astro";
const { title = "GD." } = Astro.props;
---

<div class="sticky top-0 z-30 flex h-16 w-full justify-center bg-opacity-90 backdrop-blur transition-all duration-100 bg-base-100 text-base-content shadow-sm">
  <div class="navbar max-w-[900px] w-full">
    <div class="navbar-start">
      <a class="btn btn-ghost normal-case text-xl font-mono" href="/">{title}</a>
    </div>
    <div class="navbar-center hidden sm:flex">
      <ul class="menu menu-horizontal px-1 font-mono">
        <li><a href="/">Home</a></li>
        <li><a href="/projects">Projects</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/cv">CV</a></li>
      </ul>
    </div>
    <div class="navbar-end flex space-x-2">
      <!-- Mobile menu button -->
      <div class="sm:hidden">
        <button id="mobile-menu-btn" class="btn btn-ghost btn-circle" aria-label="Open Menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
        </button>
      </div>
      <ThemeSelector />
    </div>
  </div>
</div>

<!-- Slide-over Mobile Menu -->
<div id="mobile-menu-overlay" class="fixed inset-0 z-50 bg-black/50 backdrop-blur-sm transition-opacity duration-300 opacity-0 pointer-events-none sm:hidden"></div>
<div id="mobile-menu-panel" class="fixed top-0 right-0 z-50 h-full w-64 bg-base-100 shadow-2xl flex flex-col p-6 space-y-6 text-lg font-mono transition-transform duration-300 translate-x-full sm:hidden border-l border-base-300">
  <div class="flex justify-end">
    <button id="mobile-menu-close" class="btn btn-ghost btn-circle" aria-label="Close Menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
  </div>
  <a href="/" class="hover:text-primary transition-colors py-2 border-b border-base-300">Home</a>
  <a href="/projects" class="hover:text-primary transition-colors py-2 border-b border-base-300">Projects</a>
  <a href="/blog" class="hover:text-primary transition-colors py-2 border-b border-base-300">Blog</a>
  <a href="/cv" class="hover:text-primary transition-colors py-2 border-b border-base-300">CV</a>
</div>

<script is:inline>
  function setupMobileMenu() {
    const btnOpen = document.getElementById('mobile-menu-btn');
    const btnClose = document.getElementById('mobile-menu-close');
    const overlay = document.getElementById('mobile-menu-overlay');
    const panel = document.getElementById('mobile-menu-panel');

    function openMenu() {
      overlay.classList.remove('pointer-events-none', 'opacity-0');
      overlay.classList.add('opacity-100');
      panel.classList.remove('translate-x-full');
      panel.classList.add('translate-x-0');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      overlay.classList.remove('opacity-100');
      overlay.classList.add('opacity-0', 'pointer-events-none');
      panel.classList.remove('translate-x-0');
      panel.classList.add('translate-x-full');
      document.body.style.overflow = '';
    }

    // Clean up old listeners
    const newBtnOpen = btnOpen?.cloneNode(true);
    const newBtnClose = btnClose?.cloneNode(true);
    const newOverlay = overlay?.cloneNode(true);
    
    btnOpen?.parentNode?.replaceChild(newBtnOpen, btnOpen);
    btnClose?.parentNode?.replaceChild(newBtnClose, btnClose);
    overlay?.parentNode?.replaceChild(newOverlay, overlay);

    newBtnOpen?.addEventListener('click', openMenu);
    newBtnClose?.addEventListener('click', closeMenu);
    newOverlay?.addEventListener('click', closeMenu);
  }

  setupMobileMenu();
  document.addEventListener("astro:after-swap", setupMobileMenu);
</script>
