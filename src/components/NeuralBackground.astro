<div id="neural-canvas-container" class="fixed inset-0 -z-50 opacity-55 pointer-events-none">
    <canvas id="neural-canvas" style="display: block; width: 100vw; height: 100vh; background: transparent;"></canvas>
</div>

<script is:inline>
    (function() {
        let animationId = null;
        let lastWidth = window.innerWidth;
        let lastHeight = window.innerHeight;

        function initNeural() {
            const canvas = document.getElementById("neural-canvas");
            const container = document.getElementById("neural-canvas-container");
            if (!canvas || !container) return;

            const ctx = canvas.getContext("2d");
            let particles = [];
            const particleCount = 80; 
            const connectionDistance = 150;

            function resize(force = false) {
                // Prevent mobile scroll resize glitch by checking if dimensions actually changed significantly
                // (Mobile browsers resize height when address bar hides/shows)
                const width = window.innerWidth;
                const height = window.innerHeight;
                
                if (!force && Math.abs(width - lastWidth) < 50 && Math.abs(height - lastHeight) < 150) {
                    return;
                }

                lastWidth = width;
                lastHeight = height;

                const dpr = window.devicePixelRatio || 1;
                canvas.width = width * dpr;
                canvas.height = height * dpr;
                ctx.scale(dpr, dpr);
                
                particles = [];
                for (let i = 0; i < particleCount; i++) {
                    particles.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        vx: (Math.random() - 0.5) * 0.4,
                        vy: (Math.random() - 0.5) * 0.4,
                        radius: 1.8
                    });
                }
            }

            function animate() {
                ctx.clearRect(0, 0, lastWidth, lastHeight);
                
                const dotColor = "rgba(130, 130, 130, 0.6)";
                const lineColor = "rgba(140, 140, 140, ";

                particles.forEach((p, i) => {
                    p.x += p.vx;
                    p.y += p.vy;

                    // Wrap around screen instead of bouncing for smoother feel on mobile
                    if (p.x < 0) p.x = lastWidth;
                    if (p.x > lastWidth) p.x = 0;
                    if (p.y < 0) p.y = lastHeight;
                    if (p.y > lastHeight) p.y = 0;

                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                    ctx.fillStyle = dotColor;
                    ctx.fill();

                    for (let j = i + 1; j < particles.length; j++) {
                        const p2 = particles[j];
                        const dx = p.x - p2.x;
                        const dy = p.y - p2.y;
                        const dist = Math.sqrt(dx * dx + dy * dy);
                        
                        if (dist < connectionDistance) {
                            ctx.beginPath();
                            ctx.strokeStyle = lineColor + (0.35 * (1 - dist / connectionDistance)) + ")";
                            ctx.lineWidth = 0.7;
                            ctx.moveTo(p.x, p.y);
                            ctx.lineTo(p2.x, p2.y);
                            ctx.stroke();
                        }
                    }
                });
                animationId = requestAnimationFrame(animate);
            }

            window.removeEventListener("resize", resize);
            window.addEventListener("resize", () => resize(false));
            resize(true);
            if (animationId) cancelAnimationFrame(animationId);
            animate();
        }

        document.addEventListener("astro:page-load", initNeural);
        if (document.readyState === "complete") initNeural();
        else window.addEventListener("load", initNeural);
    })();
</script>
