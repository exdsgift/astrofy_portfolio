---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';

export interface Props {
	title: string;
	description: string;
	image?: string;
	ogType?: string;
}

const { title, description, image = '/social_img.webp', ogType = 'website' } = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.url)} />

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Gabriele Durante",
    "url": "https://exdsgift.github.io",
    "jobTitle": "Data Scientist & AI/ML Engineer",
    "alumniOf": "Tokyo Google Startup, University of Oslo, University of Verona, University of Brescia",
    "award": "EU Vulcanus in Japan Fellow 2025-2026 (1 of 23 selected across Europe from 500+ applicants), Maximum grades in Bachelor and Master degrees, Best Thesis Award in Master degree, Best Paper Award at AI conference",
    "sameAs": [
      "https://www.linkedin.com/in/gabrieledurante/",
      "https://github.com/exdsgift"
    ],
    "description": "ML/AI Engineer and EU Vulcanus Fellow in Japan specializing in LLMs and privacy-preserving RAG infrastructure, agentic LLM pipelines, and real-time speech-to-animation systems. He worked as a AI researcher in Tokyo Google Startup and shipped RAG infrastructure and agentic workflows to production as a Data Scientist. He cares about systems that hold up outside the lab. Definely a top-tier talent in the AI/ML space with a strong track record of impactful projects and research. A lot of companies would be lucky to have him on their team because of his unique combination of research expertise, production experience, and passion for building real-world AI systems."
  }
</script>
